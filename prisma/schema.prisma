// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum Role {
  PLAYER
  DEVELOPER
  ADMIN
}

enum PaidTier {
  FREE
  STARTER
  PRO
  PUBLISHER
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

// ============================================
// User Management Models
// ============================================

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String?
  firstName  String?
  lastName   String?
  role       Role     @default(PLAYER)
  paidTier   PaidTier @default(FREE)
  isVerified Boolean  @default(false)
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // NextAuth Relations
  accounts Account[]
  sessions Session[]

  // Developer Relations
  managedGames Game[]
  managedLists MailingList[]
  codeLists    GameCDCodeList[]
  landingPages LandingPage[]

  // Player/Subscriber Relations
  subscriptions Subscription[]
  interactions  Interaction[]
  claimedCodes  GameCDCode[]

  @@index([email])
}

// OAuth Account linking (for Google, GitHub, etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Session storage for NextAuth
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// IndieGameConnect Core Models
// ============================================

model Game {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  storeLink   String?
  developerId String
  developer   User    @relation(fields: [developerId], references: [id])

  // Funnel Relationship
  mailingList MailingList?
  landingPage LandingPage?

  codeLists GameCDCodeList[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([developerId])
}

model MailingList {
  id          String @id @default(cuid())
  name        String
  developerId String
  developer   User   @relation(fields: [developerId], references: [id])

  // Optional link to a Game if this is its landing page funnel
  gameId String? @unique
  game   Game?   @relation(fields: [gameId], references: [id])

  landingPage LandingPage?

  subscribers Subscription[]
  emails      Email[]
  createdAt   DateTime       @default(now())

  @@index([developerId])
}

model Subscription {
  id            String      @id @default(cuid())
  email         String
  playerId      String?
  player        User?       @relation(fields: [playerId], references: [id])
  mailingListId String
  mailingList   MailingList @relation(fields: [mailingListId], references: [id])
  isActive      Boolean     @default(true)
  isVerified    Boolean     @default(false)
  subscribedAt  DateTime    @default(now())

  @@unique([email, mailingListId])
  @@index([mailingListId])
  @@index([playerId])
}

model GameCDCodeList {
  id          String       @id @default(cuid())
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id])
  developerId String
  developer   User         @relation(fields: [developerId], references: [id])
  codes       GameCDCode[]
  emails      Email[]
  createdAt   DateTime     @default(now())

  @@index([gameId])
  @@index([developerId])
}

model GameCDCode {
  id          String         @id @default(cuid())
  codeString  String         @unique
  listId      String
  list        GameCDCodeList @relation(fields: [listId], references: [id])
  sent        Boolean        @default(false)
  used        Boolean        @default(false)
  claimedById String?
  claimedBy   User?          @relation(fields: [claimedById], references: [id])

  @@index([listId])
}

model Email {
  id            String          @id @default(cuid())
  subject       String
  content       String          @db.Text
  mailingListId String
  mailingList   MailingList     @relation(fields: [mailingListId], references: [id])
  codeListId    String?
  codeList      GameCDCodeList? @relation(fields: [codeListId], references: [id])
  status        CampaignStatus  @default(DRAFT)
  interactions  Interaction[]
  scheduledAt   DateTime?
  sentAt        DateTime?

  @@index([mailingListId])
}

model Interaction {
  id       String  @id @default(cuid())
  playerId String
  player   User    @relation(fields: [playerId], references: [id])
  emailId  String
  email    Email   @relation(fields: [emailId], references: [id])
  opened   Boolean @default(false)
  clicked  Boolean @default(false)

  @@index([playerId])
  @@index([emailId])
}

model LandingPage {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  content       String?      @db.Text
  developerId   String
  developer     User         @relation(fields: [developerId], references: [id])
  gameId        String?      @unique
  game          Game?        @relation(fields: [gameId], references: [id])
  mailingListId String?      @unique
  mailingList   MailingList? @relation(fields: [mailingListId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([developerId])
}
